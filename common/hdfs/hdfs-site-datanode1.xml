<configuration>
  <property>
    <name>dfs.datanode.data.dir</name>
    <value>file:/hdfs/datanode</value>
  </property>
  <property>
    <name>dfs.datanode.data.transfer.port</name>
    <value>9866</value>
  </property>
  <!-- hostname должен совпадать с Docker network alias -->
  <property>
    <name>dfs.datanode.hostname</name>
    <value>datanode1</value>
  </property>
  <!-- слушать на всех интерфейсах -->
  <!-- RPC порт для запросов от NameNode -->
  <property>
    <name>dfs.datanode.address</name>
    <value>0.0.0.0:9970</value>
  </property>
  <!-- HTTP-порт для Web UI DataNode №1 -->
  <property>
    <name>dfs.datanode.http.address</name>
    <value>0.0.0.0:9864</value>
  </property>

  <property>
    <name>dfs.namenode.rpc-response.max-size</name>
    <value>1342177280</value>
  </property>
  <property>
    <name>dfs.datanode.max.transfer.threads</name>
    <value>4096</value>
  </property>
</configuration>
