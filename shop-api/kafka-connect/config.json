{
  "name": "allowed-products-postgres-sink",
  "config": {
    "connector.class": "io.confluent.connect.jdbc.JdbcSinkConnector",
    "tasks.max": "1",
    "topics": "allowed-products",
    "connection.url": "jdbc:postgresql://postgres:5432/shop_db",
    "connection.user": "shop_user",
    "connection.password": "shop_pass",
    "table.name.format": "product",
    "insert.mode": "upsert",
    "pk.mode": "record_value",
    "pk.fields": "product_id",
    "auto.create": "false",
    "auto.evolve": "false",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema-registry1:8081",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "transforms": "dropFields,flatten,convertCreated,convertUpdated",
    "transforms.dropFields.type": "org.apache.kafka.connect.transforms.ReplaceField$Value",
    "transforms.dropFields.exclude": "images",
    "transforms.flatten.type": "org.apache.kafka.connect.transforms.Flatten$Value",
    "transforms.flatten.delimiter": "_",
    "transforms.convertCreated.type": "org.apache.kafka.connect.transforms.TimestampConverter$Value",
    "transforms.convertCreated.field": "created_at",
    "transforms.convertCreated.format": "yyyy-MM-dd'T'HH:mm:ss'Z'",
    "transforms.convertCreated.target.type": "Timestamp",
    "transforms.convertUpdated.type": "org.apache.kafka.connect.transforms.TimestampConverter$Value",
    "transforms.convertUpdated.field": "updated_at",
    "transforms.convertUpdated.format": "yyyy-MM-dd'T'HH:mm:ss'Z'",
    "transforms.convertUpdated.target.type": "Timestamp"
  }
}